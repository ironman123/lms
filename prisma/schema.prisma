generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
}

model ExamCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  icon        String?
  image       String?
  color       String?  @default("#1D3557")
  createdAt   DateTime @default(now())
  slug        String   @unique
  exams       Exam[]
}

model Exam {
  id             String          @id @default(uuid())
  name           String          @unique
  description    String?
  duration       Int
  totalMarks     Int
  color          String          @default("#0076c5")
  examCategoryId String?
  createdAt      DateTime        @default(now())
  slug           String          @unique
  categories     Category[]
  examCategory   ExamCategory?   @relation(fields: [examCategoryId], references: [id])
  tags           ExamsTagsLink[]
  questionPapers QuestionPaper[]
}

model Tag {
  id        String          @id @default(uuid())
  name      String          @unique
  icon      String?
  color     String?
  createdAt DateTime        @default(now())
  exams     ExamsTagsLink[]
}

model ExamsTagsLink {
  id        String   @id @default(uuid())
  examId    String
  tagId     String
  createdAt DateTime @default(now())
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([examId, tagId])
}

model Category {
  id        String   @id @default(uuid())
  name      String
  examId    String
  createdAt DateTime @default(now())
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  topics    Topic[]
}

model Topic {
  id             String         @id @default(uuid())
  name           String
  categoryId     String
  parentId       String?
  createdAt      DateTime       @default(now())
  questions      Question[]
  category       Category       @relation(fields: [categoryId], references: [id])
  parent         Topic?         @relation("SubTopics", fields: [parentId], references: [id])
  children       Topic[]        @relation("SubTopics")
  topicMasteries TopicMastery[]
}

model QuestionPaper {
  id           String        @id @default(uuid())
  title        String
  year         Int?
  examId       String
  createdAt    DateTime      @default(now())
  questions    Question[]
  exam         Exam          @relation(fields: [examId], references: [id], onDelete: Cascade)
  testSessions TestSession[]
}

model Question {
  id                String                 @id @default(uuid())
  content           String
  type              QuestionType
  difficulty        Difficulty             @default(MEDIUM)
  marks             Float                  @default(1.0)
  negativeMarks     Float                  @default(0.0)
  explanation       String?
  bloomsTaxonomy    Int                    @default(1)
  isVisual          Boolean                @default(false)
  discriminationIdx Float?
  avgTimeSeconds    Int                    @default(60)
  embedding         Unsupported("vector")?
  topicId           String
  paperId           String?
  correctAnswer     String?
  createdAt         DateTime               @default(now())
  options           Option[]
  paper             QuestionPaper?         @relation(fields: [paperId], references: [id], onDelete: Cascade)
  topic             Topic                  @relation(fields: [topicId], references: [id])
  interactions      QuestionInteraction[]
}

model Option {
  id         String   @id @default(uuid())
  text       String
  isCorrect  Boolean  @default(false)
  questionId String
  createdAt  DateTime @default(now())
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model QuestionInteraction {
  id              String      @id @default(uuid())
  userId          String
  questionId      String
  sessionId       String
  visitCount      Int         @default(0)
  totalDwellTime  Int         @default(0)
  isCorrect       Boolean
  selectedAnswer  String?
  hesitationCount Int         @default(0)
  isFlagged       Boolean     @default(false)
  wasHinted       Boolean     @default(false)
  confidenceLevel Int?
  masteryDelta    Float?
  forgottenAt     DateTime?
  startedAt       DateTime    @default(now())
  createdAt       DateTime    @default(now())
  question        Question    @relation(fields: [questionId], references: [id])
  session         TestSession @relation(fields: [sessionId], references: [id])
  user            User        @relation(fields: [userId], references: [id])

  @@unique([userId, questionId, sessionId])
}

model User {
  id              String                @id @default(uuid())
  email           String                @unique
  name            String?
  region          String?
  globalMastery   Float                 @default(0.0)
  totalStudyTime  Int                   @default(0)
  accuracyRate    Float                 @default(0.0)
  avatarUrl       String?
  clerkId         String?               @unique
  college         String?
  createdAt       DateTime              @default(now())
  isPremium       Boolean               @default(false)
  lastActive      DateTime              @default(now())
  onboarded       Boolean               @default(false)
  questionsSolved Int                   @default(0)
  targetExam      String?
  role            UserRole              @default(STUDENT)
  activityLogs    ActivityLog[]
  interactions    QuestionInteraction[]
  sessions        TestSession[]
  topicMasteries  TopicMastery[]
}

model TestSession {
  id           String                @id @default(uuid())
  mode         SessionMode           @default(PRACTICE)
  startTime    DateTime              @default(now())
  endTime      DateTime?
  totalScore   Float?
  userId       String
  paperId      String
  activityLogs ActivityLog[]
  interactions QuestionInteraction[]
  paper        QuestionPaper         @relation(fields: [paperId], references: [id])
  user         User                  @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id        String      @id @default(uuid())
  sessionId String
  event     String
  metadata  Json?
  timestamp DateTime    @default(now())
  userId    String?
  session   TestSession @relation(fields: [sessionId], references: [id])
  user      User?       @relation(fields: [userId], references: [id])
}

model TopicMastery {
  id           String   @id @default(uuid())
  userId       String
  topicId      String
  currentScore Float    @default(0.0)
  lastTestedAt DateTime @default(now())
  history      Json?
  topic        Topic    @relation(fields: [topicId], references: [id])
  user         User     @relation(fields: [userId], references: [id])

  @@unique([userId, topicId])
}

enum UserRole {
  STUDENT
  ADMIN
  CONTENT_CREATOR
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionType {
  MCQ
  MSQ
  NUMERICAL
  SUBJECTIVE
}

enum SessionMode {
  PRACTICE
  MOCK_EXAM
  DIAGNOSTIC
}
