model ExamSyllabusEntry {
  id         String   @id @default(uuid())
  examId     String
  categoryId String
  topicPath  String // "Mechanics > Rotational Motion > Moment of Inertia"
  topicId    String? // soft FK to canonical Topic leaf node
  weightage  String?
  createdAt  DateTime @default(now())

  exam     Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])
  topic    Topic?   @relation(fields: [topicId], references: [id])

  @@unique([examId, topicPath])
  @@index([examId, categoryId])
}

model ExamQuestionPaperLink {
  id        String   @id @default(uuid())
  examId    String
  paperId   String
  createdAt DateTime @default(now())

  exam  Exam          @relation(fields: [examId], references: [id], onDelete: Cascade)
  paper QuestionPaper @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@unique([examId, paperId])
  @@index([examId])
  @@index([paperId])
}

model QuestionPaper {
  id        String     @id @default(uuid())
  title     String
  year      Int?
  createdAt DateTime   @default(now())
  questions Question[]
  //exam      Exam?      @relation(fields: [examId], references: [id], onDelete: Cascade)
  //examId    String?

  testSessions           TestSession[]
  examQuestionPaperLinks ExamQuestionPaperLink[]

  //@@unique([examId, title])
}

model Question {
  id                String                 @id @default(uuid())
  content           String
  type              QuestionType
  difficulty        Difficulty             @default(MEDIUM)
  marks             Float                  @default(1.0)
  negativeMarks     Float                  @default(0.0)
  explanation       String?
  bloomsTaxonomy    Int                    @default(1)
  isVisual          Boolean                @default(false)
  discriminationIdx Float?
  avgTimeSeconds    Int                    @default(60)
  embedding         Unsupported("vector")?
  topicId           String?
  topicPath         String?
  paperId           String?
  correctAnswer     String?
  createdAt         DateTime               @default(now())
  options           Option[]
  paper             QuestionPaper?         @relation(fields: [paperId], references: [id], onDelete: Cascade)
  topic             Topic?                 @relation(fields: [topicId], references: [id])
  interactions      QuestionInteraction[]
}

model Option {
  id         String   @id @default(uuid())
  text       String
  isCorrect  Boolean  @default(false)
  questionId String
  createdAt  DateTime @default(now())
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model QuestionInteraction {
  id              String      @id @default(uuid())
  userId          String
  questionId      String
  sessionId       String
  visitCount      Int         @default(0)
  totalDwellTime  Int         @default(0)
  isCorrect       Boolean
  selectedAnswer  String?
  hesitationCount Int         @default(0)
  isFlagged       Boolean     @default(false)
  wasHinted       Boolean     @default(false)
  confidenceLevel Int?
  masteryDelta    Float?
  forgottenAt     DateTime?
  startedAt       DateTime    @default(now())
  createdAt       DateTime    @default(now())
  question        Question    @relation(fields: [questionId], references: [id])
  session         TestSession @relation(fields: [sessionId], references: [id])
  user            User        @relation(fields: [userId], references: [id])

  @@unique([userId, questionId, sessionId])
}

model User {
  id              String                @id @default(uuid())
  email           String                @unique
  name            String?
  region          String?
  globalMastery   Float                 @default(0.0)
  totalStudyTime  Int                   @default(0)
  accuracyRate    Float                 @default(0.0)
  avatarUrl       String?
  clerkId         String?               @unique
  college         String?
  createdAt       DateTime              @default(now())
  isPremium       Boolean               @default(false)
  lastActive      DateTime              @default(now())
  onboarded       Boolean               @default(false)
  questionsSolved Int                   @default(0)
  targetExam      String?
  role            UserRole              @default(STUDENT)
  activityLogs    ActivityLog[]
  interactions    QuestionInteraction[]
  sessions        TestSession[]
  topicMasteries  TopicMastery[]
}

model TestSession {
  id           String                @id @default(uuid())
  mode         SessionMode           @default(PRACTICE)
  startTime    DateTime              @default(now())
  endTime      DateTime?
  totalScore   Float?
  userId       String
  paperId      String
  activityLogs ActivityLog[]
  interactions QuestionInteraction[]
  paper        QuestionPaper         @relation(fields: [paperId], references: [id])
  user         User                  @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id        String      @id @default(uuid())
  sessionId String
  event     String
  metadata  Json?
  timestamp DateTime    @default(now())
  userId    String?
  session   TestSession @relation(fields: [sessionId], references: [id])
  user      User?       @relation(fields: [userId], references: [id])
}

model TopicMastery {
  id           String   @id @default(uuid())
  userId       String
  topicId      String
  currentScore Float    @default(0.0)
  lastTestedAt DateTime @default(now())
  history      Json?
  topic        Topic    @relation(fields: [topicId], references: [id])
  user         User     @relation(fields: [userId], references: [id])

  @@unique([userId, topicId])
}

enum UserRole {
  STUDENT
  ADMIN
  CONTENT_CREATOR
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionType {
  MCQ
  MSQ
  NUMERICAL
  SUBJECTIVE
}

enum SessionMode {
  PRACTICE
  MOCK_EXAM
  DIAGNOSTIC
}
