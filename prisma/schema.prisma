// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Exam {
  id          String     @id @default(cuid())
  name        String     @unique // e.g., "GATE CSE"
  description String?
  duration    Int
  totalMarks  Int
  color       String?
  categories  Category[] // An exam has many categories (Engineering Math, OS, etc.)
}

model Category {
  id      String  @id @default(cuid())
  name    String  // e.g., "General Aptitude"
  exam    Exam    @relation(fields: [examId], references: [id])
  examId  String
  topics  Topic[] // A category has many topics (Verbal Ability, Numerical)
}

model Topic {
  id         String   @id @default(cuid())
  name       String   // e.g., "Linear Algebra"
  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String
}