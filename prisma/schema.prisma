// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
  //output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  STUDENT
  ADMIN
  CONTENT_CREATOR // For people just uploading GATE questions
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionType {
  MCQ // Single correct answer
  MSQ // Multiple Select (Multiple correct answers)
  NUMERICAL // Integer or Decimal input (Common in GATE)
  SUBJECTIVE // Text-based long answers (Common in UPSC/KPSC)
}

enum SessionMode {
  PRACTICE // No timer, hints allowed
  MOCK_EXAM // Strict timer, no hints, simulates real GATE/UPSC
  DIAGNOSTIC // Initial test to map "Mastery"
}

// This is the structure you should use for the Exams/Syllabus
model Exam {
  id             String          @id @default(uuid())
  name           String          @unique // e.g., "GATE CSE"
  description    String?
  duration       Int
  totalMarks     Int
  color          String          @default("#0076c5") // Hex color code for UI representation
  categories     Category[] // An exam has many categories (Engineering Math, OS, etc.)
  questionPapers QuestionPaper[]
}

model Category {
  id     String  @id @default(uuid())
  name   String // e.g., "General Aptitude"
  exam   Exam    @relation(fields: [examId], references: [id])
  examId String
  topics Topic[] // A category has many topics (Verbal Ability, Numerical)
}

model Topic {
  id         String   @id @default(uuid())
  name       String // e.g., "Linear Algebra"
  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String

  // The Knowledge Graph: Prerequisites
  parentId String?
  parent   Topic?  @relation("SubTopics", fields: [parentId], references: [id])
  children Topic[] @relation("SubTopics")

  questions      Question[]
  topicMasteries TopicMastery[]
}

model QuestionPaper {
  id           String        @id @default(uuid())
  title        String // e.g., "GATE CSE 2024 Mock 1"
  year         Int?
  exam         Exam          @relation(fields: [examId], references: [id])
  examId       String
  questions    Question[]
  createdAt    DateTime      @default(now())
  testSessions TestSession[]
}

model Question {
  id            String       @id @default(uuid())
  content       String // Supports KaTeX/Markdown
  type          QuestionType
  difficulty    Difficulty   @default(MEDIUM)
  marks         Float        @default(1.0)
  negativeMarks Float        @default(0.0)
  explanation   String?

  // Scientist Metadata
  bloomsTaxonomy    Int     @default(1) // 1-6 (Recall to Create)
  isVisual          Boolean @default(false)
  discriminationIdx Float? // Statistical quality of the question
  avgTimeSeconds    Int     @default(60)

  // Semantic Intelligence (Requires pgvector)
  embedding Unsupported("vector(1536)")?

  // Relations
  topic        Topic                 @relation(fields: [topicId], references: [id])
  topicId      String
  paper        QuestionPaper?        @relation(fields: [paperId], references: [id])
  paperId      String?
  options      Option[]
  interactions QuestionInteraction[]

  correctAnswer String?
}

model Option {
  id         String   @id @default(uuid())
  text       String
  isCorrect  Boolean  @default(false)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId String
}

model QuestionInteraction {
  id String @id @default(uuid())

  // Linkages
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  questionId String
  question   Question    @relation(fields: [questionId], references: [id])
  sessionId  String
  session    TestSession @relation(fields: [sessionId], references: [id])

  // Telemetry (The "Big Data" for training)
  visitCount     Int     @default(0) // How many times they attempted/viewed the question 
  totalDwellTime Int     @default(0) // How long they looked (ms)
  isCorrect      Boolean
  selectedAnswer String?

  // Metadata for AI-Driven Personalization
  hesitationCount Int     @default(0) // How many times they toggled options
  isFlagged       Boolean @default(false) // Subjective uncertainty
  wasHinted       Boolean @default(false) // Did they view the hint/explanation?
  confidenceLevel Int? // 1-5 scale of self-reported confidence

  // Learning Science Analytics
  masteryDelta Float? // How much their "Mastery Score" changed
  forgottenAt  DateTime? // Predicted date of memory decay

  startedAt DateTime @default(now())
  createdAt DateTime @default(now())

  @@unique([userId, questionId, sessionId]) // The "Secret Sauce" for clean Big Data. History of how they answered that same question across different months
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  role      UserRole @default(STUDENT)
  avatarUrl String? // For the Leaderboard UI
  clerkId   String?  @unique // To sync with your Auth provider

  // Demographics & Context
  region     String? // e.g., "Uttar Pradesh", "Tamil Nadu"
  targetExam String? // e.g., "GATE 2026", "UPSC"
  college    String? // To compare performance across institutions

  // Intelligence Metrics (Aggregated)
  globalMastery   Float @default(0.0)
  totalStudyTime  Int   @default(0)
  questionsSolved Int   @default(0) // Fast counter for UI
  accuracyRate    Float @default(0.0) // (Correct / Total)

  // Platform State
  isPremium  Boolean  @default(false) // For paywalled mock tests
  onboarded  Boolean  @default(false) // To track first-time setup
  lastActive DateTime @default(now())
  createdAt  DateTime @default(now())

  // Relations
  sessions       TestSession[]
  interactions   QuestionInteraction[]
  topicMasteries TopicMastery[]
  activityLogs   ActivityLog[]
}

model TestSession {
  id         String      @id @default(uuid())
  mode       SessionMode @default(PRACTICE)
  startTime  DateTime    @default(now())
  endTime    DateTime?
  totalScore Float?

  // Relations
  user    User          @relation(fields: [userId], references: [id])
  userId  String
  paper   QuestionPaper @relation(fields: [paperId], references: [id])
  paperId String

  // The collection of every interaction in THIS specific test attempt
  interactions QuestionInteraction[]
  activityLogs ActivityLog[]
}

model ActivityLog {
  id        String      @id @default(uuid())
  sessionId String
  session   TestSession @relation(fields: [sessionId], references: [id])

  // The "What" happened
  event    String // e.g., "NAVIGATE_TO_Q5", "VIEWED_HINT", "WINDOW_BLUR"
  metadata Json? // Stores extra info like { fromQ: 4, toQ: 5 }

  timestamp DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
}

model TopicMastery {
  id      String @id @default(uuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id])
  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id])

  // The "Scientist" Data
  currentScore Float    @default(0.0) // 0.0 to 1.0 (0% to 100% mastery)
  lastTestedAt DateTime @default(now())

  // This allows us to see how mastery changes over weeks
  history Json? // Optional: Stores [ {date: "2026-03-01", score: 0.4}, ... ]

  @@unique([userId, topicId])
}
