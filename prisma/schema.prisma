generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
}

model ExamCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  icon        String?
  image       String?
  color       String?  @default("#1D3557")
  createdAt   DateTime @default(now())
  slug        String   @unique
  exams       Exam[]
}

model Exam {
  id                     String                  @id @default(uuid())
  name                   String                  @unique
  description            String?
  duration               Int
  categoryNumber         String?                 @unique
  totalMarks             Int
  color                  String                  @default("#0076c5")
  examCategoryId         String?
  createdAt              DateTime                @default(now())
  slug                   String                  @unique
  //categories     Category[]
  examCategory           ExamCategory?           @relation(fields: [examCategoryId], references: [id])
  tags                   ExamsTagsLink[]
  //questionPapers         QuestionPaper[]
  //examTopics     ExamTopic[]
  syllabusEntries        ExamSyllabusEntry[]
  examQuestionPaperLinks ExamQuestionPaperLink[]
}

model Tag {
  id        String          @id @default(uuid())
  name      String          @unique
  icon      String?
  color     String?
  createdAt DateTime        @default(now())
  exams     ExamsTagsLink[]
}

model ExamsTagsLink {
  id        String   @id @default(uuid())
  examId    String
  tagId     String
  createdAt DateTime @default(now())
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([examId, tagId])
}

model Category {
  id                  String              @id @default(uuid())
  name                String              @unique
  //examId    String
  //exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  createdAt           DateTime            @default(now())
  topics              Topic[]
  examSyllabusEntries ExamSyllabusEntry[]
}

model Topic {
  id         String   @id @default(uuid())
  name       String
  categoryId String
  parentId   String?
  createdAt  DateTime @default(now())

  level     Int     @default(0) // 0 = Chapter, 1 = Topic, 2 = Sub-topic
  isLeaf    Boolean @default(true) // Quick check: Can I attach a question here?
  weightage String? // To store things like "12 marks" from your PDF
  slug      String?

  questions       Question[]
  category        Category            @relation(fields: [categoryId], references: [id])
  parent          Topic?              @relation("SubTopics", fields: [parentId], references: [id])
  children        Topic[]             @relation("SubTopics")
  topicMasteries  TopicMastery[]
  //examTopics     ExamTopic[]
  syllabusEntries ExamSyllabusEntry[]

  // This prevents two "Moment of Inertia" topics under the same parent
  @@unique([name, parentId])
  // This allows you to find top-level chapters by name + category
  @@unique([name, categoryId])
  // Index for faster tree traversal
  @@index([parentId])
}

